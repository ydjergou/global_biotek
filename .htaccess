# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION BEGIN
PassengerAppRoot "/home/htesbanzny/global-biotek"
PassengerBaseURI "/"
PassengerPython "/home/htesbanzny/virtualenv/global-biotek/3.12/bin/python"
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION END

# Cache pour les assets statiques
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Sécurité : bloque l'accès direct aux fichiers sensibles
<FilesMatch "\.(pkl|csv|env)$">
    Order allow,deny
    Deny from all
</FilesMatch>
<FilesMatch "^(passenger_wsgi\.py|app\.py|model_utils\.py|generate_mock_data\.py)$">
    Order allow,deny
    Deny from all
</FilesMatch>
